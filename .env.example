APP_NAME=ChronosIntel
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# CORS
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Database
# SQLite (development — default):
DATABASE_URL=sqlite+aiosqlite:///./chronosintel.db
# PostgreSQL (production — uncomment and fill):
# DATABASE_URL=postgresql+asyncpg://chronos_user:your_password@db:5432/chronosintel

# Cognee Knowledge Graph
COGNEE_API_KEY=
COGNEE_LLM_PROVIDER=gemini
COGNEE_LLM_MODEL=gemini-2.0-flash
COGNEE_EMBEDDING_PROVIDER=gemini
COGNEE_EMBEDDING_MODEL=models/text-embedding-004
COGNEE_DB_PATH=./storage/cognee_db

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_OUTPUT_TOKENS=8192

# Storage Paths
UPLOAD_DIR=./storage/uploads
PROCESSED_DIR=./storage/processed
REPORT_DIR=./storage/reports
MAX_UPLOAD_SIZE_MB=50

# File Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Investigation
MAX_EVIDENCE_RESULTS=20
EVIDENCE_SCORE_THRESHOLD=0.5
